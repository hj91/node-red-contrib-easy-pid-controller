    {
        "id": "27821f05268e7bf4",
        "type": "function",
        "z": "d216577e3e3a3883",
        "name": "Map → InfluxDB fields",
        "func": "// Map all v2.0.0 payload fields to explicit InfluxDB field set\n// Ensures error, output, and mode are stored alongside P/I/D\nvar p = msg.payload;\nmsg.payload = [\n  {\n    PV:     p.PV,\n    SV:     p.SV,\n    error:  p.error,\n    P:      p.P,\n    I:      p.I,\n    D:      p.D,\n    output: p.output,\n    Signal: p.Signal,\n    Value:  p.Value,\n    mode:   p.mode\n  },\n  { mode: p.mode }\n];\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 840,
        "y": 360,
        "wires": [
